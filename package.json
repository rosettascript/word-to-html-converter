{
  "name": "word-to-html-converter",
  "version": "1.0.0",
  "description": "A free, client-side tool for cleaning Word-to-HTML output. Remove inline styles, preserve semantic structure, and format HTML for Shopify or regular use.",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "dev": "python3 -m http.server 5173",
    "serve": "npx serve .",
    "start": "npx serve .",
    "security": "npm audit",
    "lint": "eslint js/**/*.js",
    "lint:fix": "eslint js/**/*.js --fix",
    "format": "prettier --write js/**/*.js *.js *.json",
    "format:check": "prettier --check js/**/*.js *.js *.json"
  },
  "keywords": [
    "word-to-html",
    "html-cleaner",
    "shopify",
    "html-converter",
    "inline-styles",
    "semantic-html"
  ],
  "author": "Kim Galicia",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitest/ui": "^4.0.13",
    "eslint": "^9.39.1",
    "jsdom": "^23.0.0",
    "prettier": "^3.6.2",
    "vitest": "^4.0.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rosettascript/word-to-html-converter.git"
  },
  "bugs": {
    "url": "https://github.com/rosettascript/word-to-html-converter/issues"
  },
  "homepage": "https://rosettascript.github.io/word-to-html-converter/",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.html",
    "shopify.html",
    "css/",
    "js/",
    "assets/",
    "tutorials/",
    "robots.txt",
    "sitemap.xml",
    "README.md",
    "LICENSE"
  ]
}
